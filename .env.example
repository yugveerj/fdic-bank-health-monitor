# Copy to .env and fill in. .env is gitignored — secrets never enter the repo.
# In CI, the same names live as GitHub Actions secrets (or arrive via WIF).

# GCP project for the BigQuery warehouse. Auth is Application Default
# Credentials: `gcloud auth application-default login` locally, Workload
# Identity Federation in CI — no key file needed either way.
GCP_PROJECT=

# BigQuery raw dataset + location. Defaults shown; only set to override.
# Location is US multi-region to match the GA4 export and bigquery-public-data.
BQ_RAW_DATASET=fdic_raw
BQ_LOCATION=US

# MotherDuck service token — motherduck.com → Settings → Access Tokens.
# Still needed during the v2 migration for parity checks against the old
# warehouse; retired when MotherDuck is decommissioned (Phase C).
MOTHERDUCK_TOKEN=

# FRED API key — https://fred.stlouisfed.org/docs/api/api_key.html (free, instant)
FRED_API_KEY=
