# Copy to .env and fill in. .env is gitignored — secrets never enter the repo.
# In CI, the same names live as GitHub Actions secrets.

# MotherDuck service token — motherduck.com → Settings → Access Tokens
MOTHERDUCK_TOKEN=

# FRED API key — https://fred.stlouisfed.org/docs/api/api_key.html (free, instant)
FRED_API_KEY=
